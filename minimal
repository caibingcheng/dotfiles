#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

# =============================================================================
# Dotfiles Minimal Installation
# Installs essential tools and configures the base environment
# =============================================================================

# Update git hosts
update_github_hosts() {
    local hosts_url="https://cdn.jsdelivr.net/gh/caibingcheng/hosts@main/dns/github"
    local tmp_hosts="/tmp/hosts_github"

    if [[ ! -f "${tmp_hosts}" ]]; then
        echo "Downloading GitHub hosts..."
        if ! curl -fsSL "${hosts_url}" -o "${tmp_hosts}" 2>/dev/null; then
            echo "Warning: Failed to download GitHub hosts, skipping..." >&2
            return 0
        fi
    fi

    ${SUDO} bash -c '
        set -euo pipefail
        tmp_hosts_tmp="$(mktemp)"
        trap "rm -f \"$tmp_hosts_tmp\"" EXIT
        grep -v github /etc/hosts >"$tmp_hosts_tmp"
        cat "$1" >>"$tmp_hosts_tmp"
        cp "$tmp_hosts_tmp" /etc/hosts
    ' bash "${tmp_hosts}"
}

# Auto-detect and repair broken apt sources (missing Release files and expired GPG keys), then retry.
# Works across Ubuntu 20.04 / 22.04 / 24.04 without any hardcoded repo or key IDs.
_apt_update_with_repair() {
    local output exit_code repaired=false

    output=$(${SUDO} apt update 2>&1)
    exit_code=$?
    echo "$output"
    [[ $exit_code -eq 0 ]] && return 0

    # Disable source files for repos that no longer publish a Release file (404 / discontinued PPAs)
    local bad_repo_urls
    bad_repo_urls=$(echo "$output" | grep "does not have a Release file" | \
        grep -oP 'https?://\S+' || true)
    while IFS= read -r repo_url; do
        [[ -z "$repo_url" ]] && continue
        local source_files
        source_files=$(grep -rl "$repo_url" /etc/apt/sources.list.d/ 2>/dev/null || true)
        if [[ -n "$source_files" ]]; then
            while IFS= read -r f; do
                echo "Disabling invalid source: $f"
                ${SUDO} mv "$f" "${f}.disabled"
            done <<< "$source_files"
            repaired=true
        fi
    done <<< "$bad_repo_urls"

    # Refresh expired or missing GPG keys (supports Ubuntu 20.04-24.04)
    local bad_keys
    bad_keys=$(echo "$output" | grep -oP '(?<=EXPKEYSIG |NO_PUBKEY )[A-F0-9]+' | sort -u || true)
    while IFS= read -r key; do
        [[ -z "$key" ]] && continue
        echo "Refreshing GPG key: $key"
        # apt-key is deprecated on 22.04+ but still functional; fallback uses trusted.gpg.d
        ${SUDO} apt-key adv --keyserver keyserver.ubuntu.com --recv-keys "$key" 2>/dev/null || \
            curl -fsSL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x${key}" | \
            gpg --dearmor | ${SUDO} tee "/etc/apt/trusted.gpg.d/${key}.gpg" >/dev/null 2>&1 || true
        repaired=true
    done <<< "$bad_keys"

    if [[ "$repaired" == true ]]; then
        echo "Retrying apt update after repairs..."
        ${SUDO} apt update || {
            echo "Warning: apt update still failing after repairs." >&2
            return 1
        }
    else
        echo "Warning: apt update failed with unrecognized errors." >&2
        return 1
    fi
}

# Install base packages
install_base_packages() {
    if [[ -z "${APT_UPDATED_DONE:-}" ]]; then
        _apt_update_with_repair
        export APT_UPDATED_DONE=true
    fi

    # Fix any pre-existing broken dependencies before installing
    ${SUDO} apt --fix-broken install -y

    ${SUDO} apt install -y \
        curl wget git preload \
        vim make \
        build-essential gcc g++ gdb \
        python3 python3-pip python3-venv python3-dev pipx
}

# Install Homebrew
install_homebrew() {
    if ! command -v brew &>/dev/null; then
        echo "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        {
            echo
            echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"'
        } >> "${HOME}/.bashrc"
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    fi

    # Configure Homebrew mirrors
    export HOMEBREW_API_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles/api"
    export HOMEBREW_BOTTLE_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles"
    export HOMEBREW_BREW_GIT_REMOTE="https://mirrors.ustc.edu.cn/brew.git"
    export HOMEBREW_CORE_GIT_REMOTE="https://mirrors.ustc.edu.cn/homebrew-core.git"

    brew update
    export HOMEBREW_NO_AUTO_UPDATE=true
    brew bundle --file "${DOTFILES_ROOT}/brew/minimal.brewfile" install
}

# Install Rust
install_rust() {
    if ! command -v rustup &>/dev/null; then
        echo "Installing Rust..."
        # shellcheck source=/dev/null
        source "${DOTFILES_ROOT}/rust/install"
    fi
}

# Update tldr cache
update_tldr() {
    if command -v tldr &>/dev/null; then
        tldr --update 2>/dev/null || true
    fi
}

# Install Go tools
install_cargo_tools() {
    if command -v cargo &>/dev/null; then
        if command -v exa &>/dev/null; then
            echo "Removing deprecated exa..."
            cargo uninstall exa 2>/dev/null || true
        fi
    fi
}

# Install Node.js with nvm
install_node() {
    if ! command -v nvm &>/dev/null && [[ ! -d "${NVM_DIR:-$HOME/.nvm}" ]]; then
        echo "Installing Node.js..."
        # shellcheck source=/dev/null
        source "${DOTFILES_ROOT}/node/install"
    else
        echo "Node.js already installed (nvm found)"
    fi
}

# Main
main() {
    echo "Starting minimal installation..."

    update_github_hosts
    install_base_packages
    install_rust
    install_node
    install_homebrew
    update_tldr
    install_cargo_tools

    echo "Minimal installation completed!"
}

main "$@"
