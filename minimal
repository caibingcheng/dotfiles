#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

# =============================================================================
# Dotfiles Minimal Installation
# Installs essential tools and configures the base environment
# =============================================================================

# Update git hosts
update_github_hosts() {
    local hosts_url="https://cdn.jsdelivr.net/gh/caibingcheng/hosts@main/dns/github"
    local tmp_hosts="/tmp/hosts_github"

    if [[ ! -f "${tmp_hosts}" ]]; then
        echo "Downloading GitHub hosts..."
        if ! curl -fsSL "${hosts_url}" -o "${tmp_hosts}" 2>/dev/null; then
            echo "Warning: Failed to download GitHub hosts, skipping..." >&2
            return 0
        fi
    fi

    ${SUDO} bash -c '
        set -euo pipefail
        tmp_hosts_tmp="$(mktemp)"
        trap "rm -f \"$tmp_hosts_tmp\"" EXIT
        grep -v github /etc/hosts >"$tmp_hosts_tmp"
        cat "$1" >>"$tmp_hosts_tmp"
        cp "$tmp_hosts_tmp" /etc/hosts
    ' bash "${tmp_hosts}"
}

# Install base packages
install_base_packages() {
    if [[ -z "${APT_UPDATED_DONE:-}" ]]; then
        ${SUDO} apt update
        export APT_UPDATED_DONE=true
    fi

    ${SUDO} apt install -y \
        curl wget git preload \
        vim make \
        build-essential gcc g++ gdb \
        python3 python3-pip python3-venv python3-dev pipx
}

# Install Homebrew
install_homebrew() {
    if ! command -v brew &>/dev/null; then
        echo "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        {
            echo
            echo 'eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"'
        } >> "${HOME}/.bashrc"
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    fi

    # Configure Homebrew mirrors
    export HOMEBREW_API_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles/api"
    export HOMEBREW_BOTTLE_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles"
    export HOMEBREW_BREW_GIT_REMOTE="https://mirrors.ustc.edu.cn/brew.git"
    export HOMEBREW_CORE_GIT_REMOTE="https://mirrors.ustc.edu.cn/homebrew-core.git"

    brew update
    export HOMEBREW_NO_AUTO_UPDATE=true
    brew bundle --file "${DOTFILES_ROOT}/brew/minimal.brewfile" install
}

# Install Rust
install_rust() {
    if ! command -v rustup &>/dev/null; then
        echo "Installing Rust..."
        # shellcheck source=/dev/null
        source "${DOTFILES_ROOT}/rust/install"
    fi
}

# Update tldr cache
update_tldr() {
    if command -v tldr &>/dev/null; then
        tldr --update 2>/dev/null || true
    fi
}

# Install Go tools
install_cargo_tools() {
    if command -v cargo &>/dev/null; then
        if command -v exa &>/dev/null; then
            echo "Removing deprecated exa..."
            cargo uninstall exa 2>/dev/null || true
        fi
    fi
}

# Main
main() {
    echo "Starting minimal installation..."

    update_github_hosts
    install_base_packages
    install_rust
    install_homebrew
    update_tldr
    install_cargo_tools

    echo "Minimal installation completed!"
}

main "$@"
