#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

source "${DOTFILES_ROOT}/minimal"

if [[ -z "${APT_UPDATED_DONE:-}" ]]; then
    ${SUDO} apt update
    export APT_UPDATED_DONE=true
fi

${SUDO} apt install -y gnome-tweaks meld wireshark
${SUDO} apt install -y ibus-rime librime-data-pinyin-simp
${SUDO} apt install -y flameshot

export HOMEBREW_NO_AUTO_UPDATE=true
brew bundle --file "${DOTFILES_ROOT}/brew/standard.brewfile"

# Install or update vscode
vscode_repo="https://packages.microsoft.com/repos/vscode/pool/main/c/code/"
vscode_version=$(command -v code &>/dev/null && code --version | grep -oP '(\d+\.)+\d+' || echo "0.0.0")
vscode_latest=$(curl -fsSL "${vscode_repo}" 2>/dev/null | grep -oP 'code_.*?_amd64\.deb' | sort -V | tail -n 1 || true)

echo "VSCode - Latest: ${vscode_latest}, Current: ${vscode_version}"

if [[ "${vscode_latest}" == *"${vscode_version}"* ]]; then
    echo "VSCode is up to date"
elif [[ -z "${vscode_latest}" ]]; then
    echo "Failed to get latest VSCode version"
else
    vscode_url="${vscode_repo}${vscode_latest}"
    echo "Downloading ${vscode_url}"
    if wget --https-only --tries=3 --timeout=30 -q --show-progress -O /tmp/vscode.deb "${vscode_url}"; then
        ${SUDO} dpkg -i /tmp/vscode.deb
        ${SUDO} apt install -f -y
        rm -f /tmp/vscode.deb
    fi
fi

# Install or update edge
edge_repo="https://packages.microsoft.com/repos/edge/pool/main/m/microsoft-edge-stable/"
edge_version=$(command -v microsoft-edge-stable &>/dev/null && microsoft-edge-stable --version | grep -oP '(\d+\.)+\d+' || echo "0.0.0")
edge_latest=$(curl -fsSL "${edge_repo}" 2>/dev/null | grep -oP 'microsoft-edge-stable_.*?_amd64\.deb' | sort -V | tail -n 1 || true)

echo "Edge - Latest: ${edge_latest}, Current: ${edge_version}"

if [[ "${edge_latest}" == *"${edge_version}"* ]]; then
    echo "Edge is up to date"
elif [[ -z "${edge_latest}" ]]; then
    echo "Failed to get latest Edge version"
else
    edge_url="${edge_repo}${edge_latest}"
    echo "Downloading ${edge_url}"
    if wget --https-only --tries=3 --timeout=30 -q --show-progress -O /tmp/edge.deb "${edge_url}"; then
        ${SUDO} dpkg -i /tmp/edge.deb
        ${SUDO} apt install -f -y
        rm -f /tmp/edge.deb
    fi
fi
