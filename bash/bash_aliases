# test -x "$(command -v thefuck)" && eval $(thefuck --alias ff)

function _builtin_cd() {
    builtin cd "$@" &&
    if [[ -f ".autorun" ]]; then
        source .autorun
    fi
}

function _zoxide_cd() {
    z "$@" &&
    if [[ -f ".autorun" ]]; then
        source .autorun
    fi
}

alias cd="_builtin_cd"
alias z="_zoxide_cd"
alias cd-="_builtin_cd -"
alias cd..="_builtin_cd .."
alias z-="_zoxide_cd -"
alias z..="_zoxide_cd .."
alias ..="_zoxide_cd .."
alias ...="_zoxide_cd .."
alias ....="_zoxide_cd ../.."

alias zc='__zc() { local cur=$(pwd) && z "$@" && echo $(pwd) && code . && z ${cur}; } && __zc'

_vv() {
    venv_dir="$HOME/venvs"
    venv_list=$(ls $venv_dir)
    local pre cur opts
    COMPREPLY=()
    pre="${COMP_WORDS[COMP_CWORD-1]}"
    cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=($(compgen -W "${venv_list}" -- ${cur}))
}
test -x "vv" && unalias vv
complete -F _vv vv
alias vv='__vv() {
    if [ "$1" == "create" ]; then
        shift
        python3 -m venv $HOME/venvs/"$1"
        complete -F _vv vv
    elif [ "$1" == "delete" ]; then
        shift
        rm -rf $HOME/venvs/"$1"
        complete -F _vv vv
    else
        source $HOME/venvs/"$1"/bin/activate
    fi
} && __vv'

_swap() {
    left=$1
    right=$2
    left_tmp=$left.$RANDOM
    if [[ -f $left_tmp || -d $left_tmp ]]; then
        echo "try again!"
        return 1
    fi
    if [[ ! -f $left && ! -d $left ]]; then
        echo "$left not exsit!"
        return 1
    fi
    if [[ ! -f $right && ! -d $right ]]; then
        echo "$right not exsit!"
        return 1
    fi
    rename $left $left_tmp $left
    rename $right $left $right
    rename $left_tmp $right $left_tmp
}
alias swap='_swap'

