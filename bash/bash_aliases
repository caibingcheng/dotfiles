#!/bin/bash

# Source git aliases
if [ -f ~/.git_aliases ]; then
    . ~/.git_aliases
fi

alias sba=". ~/.bashrc"
alias ssba=". ~/.bash_profile"
alias crc="command -v code &>/dev/null && code ~/.dotfiles || vim ~/.dotfiles"
alias dotfiles="${HOME}/.dotfiles/bootstrap"

alias oo="opencode"

alias ssh="/bin/ssh -o ServerAliveInterval=60 -o ServerAliveCountMax=10"
alias ntpon="timedatectl set-ntp yes"
alias ntpoff="timedatectl set-ntp no"

command -v eza &>/dev/null && alias ls="eza"
command -v fd &>/dev/null && alias fd="fd --hidden --no-ignore "
command -v fdfind &>/dev/null && alias fd="fdfind --hidden --no-ignore "
command -v batcat &>/dev/null && alias bat="batcat"
alias ll="ls -lh"
alias la="ls -lha"
alias cls="clear"
alias c="code ."
alias line="wc -l"
alias word="wc -w"
alias byte="wc -c"
alias bat="bat --color=always"
alias mmem="ps aux --sort=-%mem | head -n 20"
alias mm="make -j$(nproc)"

alias tt="tldr"
alias rr="ranger"
# ff alias for thefuck
# ll alias for ls -lh
# mm alias for make

# FZF integration (fzf 0.48.0+ supports --bash option)
if command -v fzf &>/dev/null; then
    eval "$(fzf --bash)"
fi
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init bash)"
else
    alias z="cd"
fi
# test -x "$(command -v thefuck)" && eval $(thefuck --alias ff)

function _builtin_cd() {
    builtin cd "$@" &&
    if [[ -f ".autorun" ]]; then
        source .autorun
    fi
}

function _zoxide_cd() {
    z "$@" &&
    if [[ -f ".autorun" ]]; then
        source .autorun
    fi
}

alias cd="_builtin_cd"
alias z="_zoxide_cd"
alias cd-="_builtin_cd -"
alias cd..="_builtin_cd .."
alias z-="_zoxide_cd -"
alias z..="_zoxide_cd .."
alias ..="_zoxide_cd .."
alias ...="_zoxide_cd .."
alias ....="_zoxide_cd ../.."

alias zc='__zc() { local cur=$(pwd) && z "$@" && echo $(pwd) && code . && z ${cur}; } && __zc'

_vv() {
    venv_dir="$HOME/venvs"
    venv_list=$(ls $venv_dir)
    local pre cur opts
    COMPREPLY=()
    pre="${COMP_WORDS[COMP_CWORD-1]}"
    cur="${COMP_WORDS[COMP_CWORD]}"
    COMPREPLY=($(compgen -W "${venv_list}" -- ${cur}))
}
test -x "vv" && unalias vv
complete -F _vv vv
alias vv='__vv() {
    if [ "$1" == "create" ]; then
        shift
        python3 -m venv $HOME/venvs/"$1"
        complete -F _vv vv
    elif [ "$1" == "delete" ]; then
        shift
        rm -rf $HOME/venvs/"$1"
        complete -F _vv vv
    else
        source $HOME/venvs/"$1"/bin/activate
    fi
} && __vv'

_swap() {
    left=$1
    right=$2
    left_tmp=$left.$RANDOM
    if [[ -f $left_tmp || -d $left_tmp ]]; then
        echo "try again!"
        return 1
    fi
    if [[ ! -f $left && ! -d $left ]]; then
        echo "$left not exsit!"
        return 1
    fi
    if [[ ! -f $right && ! -d $right ]]; then
        echo "$right not exsit!"
        return 1
    fi
    rename $left $left_tmp $left
    rename $right $left $right
    rename $left_tmp $right $left_tmp
}
alias swap='_swap'

alias makearm="make CROSS_COMPILE=aarch64-linux-gnu-"
alias netrestart="sudo systemctl restart NetworkManager.service"

alias br="bear -l /usr/lib/x86_64-linux-gnu/bear/libear.so make -j12"

_ask_question_by_opencode() {
    local message="$1"
    local agent="ask"
    local model="github-copilot/gpt-4o"
    local extra_args=()

    shift
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --agent)
                if [[ -n "$2" ]]; then
                    agent="$2"
                    shift 2
                else
                    echo "aa: --agent requires a value"
                    return 1
                fi
                ;;
            --model)
                if [[ -n "$2" ]]; then
                    model="$2"
                    shift 2
                else
                    echo "aa: --model requires a value"
                    return 1
                fi
                ;;
            *)
                extra_args+=("$1")
                shift
                ;;
        esac
    done

    opencode --agent "$agent" --pure --model "$model" run "$message" "${extra_args[@]}" | glow
}

alias aa="_ask_question_by_opencode"
