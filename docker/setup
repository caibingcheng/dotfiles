#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

# shellcheck source=../lib/common.sh
source "${DOTFILES_ROOT}/lib/common.sh"

log_info "Configuring docker..."

# Create docker config directory
ensure_dir "${HOME}/.docker"

# Link docker aliases
safe_link "${DOTFILES_ROOT}/docker/docker_aliases" "${HOME}/.docker_aliases"

# Source docker aliases in bashrc
if ! grep -q "docker_aliases" "${HOME}/.bashrc" 2>/dev/null; then
    log_info "Adding docker aliases to .bashrc..."
    echo '' >> "${HOME}/.bashrc"
    echo '# Docker aliases' >> "${HOME}/.bashrc"
    echo 'if [ -f ~/.docker_aliases ]; then' >> "${HOME}/.bashrc"
    echo '    . ~/.docker_aliases' >> "${HOME}/.bashrc"
    echo 'fi' >> "${HOME}/.bashrc"
fi

# Setup docker compose completions
if command -v docker &>/dev/null; then
    ensure_dir "${HOME}/.docker/completions"
    docker completion bash > "${HOME}/.docker/completions/docker.bash" 2>/dev/null || true
fi

log_info "Docker configuration complete!"
