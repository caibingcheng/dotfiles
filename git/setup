#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

# shellcheck source=../lib/common.sh
source "${DOTFILES_ROOT}/lib/common.sh" 2>/dev/null || true

git_check_user() {
    [[ -n "$(git config --global user.name 2>/dev/null || true)" ]] && \
    [[ -n "$(git config --global user.email 2>/dev/null || true)" ]]
}

git_config_user() {
    local user_name="" user_email=""

    # 1. Check environment variables first
    user_name="${GIT_USER_NAME:-}"
    user_email="${GIT_USER_EMAIL:-}"

    if [[ -n "${user_name}" && -n "${user_email}" ]]; then
        log_info "Using git config from environment variables"
        git config --global user.name "${user_name}"
        git config --global user.email "${user_email}"
        return 0
    fi

    # 2. Skip in CI environment
    if [[ "${CI:-}" == "true" ]]; then
        log_info "CI environment detected, skipping interactive git config"
        log_info "Set GIT_USER_NAME and GIT_USER_EMAIL to configure git"
        return 0
    fi

    # 3. Check if /dev/tty is available
    if [[ ! -e /dev/tty ]]; then
        log_warn "Non-interactive mode detected (no /dev/tty)"
        log_warn "Please configure git manually:"
        log_warn "  git config --global user.name \"Your Name\""
        log_warn "  git config --global user.email \"your@email.com\""
        return 0
    fi

    # 4. Read from /dev/tty for interactive input
    while [[ -z "${user_name}" ]]; do
        read -r -p "    user.name: " user_name < /dev/tty
    done
    while [[ -z "${user_email}" ]]; do
        read -r -p "    user.email: " user_email < /dev/tty
    done
    git config --global user.name "${user_name}"
    git config --global user.email "${user_email}"
}

if command -v git &>/dev/null; then
    git_check_user || git_config_user
    ln -sf "${DOTFILES_ROOT}/git/git-completion.bash" "${HOME}/.git-completion.bash"
    ln -sf "${DOTFILES_ROOT}/git/gitconfig" "${HOME}/.gitconfig"
    ln -sf "${DOTFILES_ROOT}/git/gitignore_global" "${HOME}/.gitignore_global"
    ln -sf "${DOTFILES_ROOT}/git/git_aliases" "${HOME}/.git_aliases"
fi

# Source git aliases in bashrc if not already present
if ! grep -q "git_aliases" "${HOME}/.bashrc" 2>/dev/null; then
    # shellcheck source=/dev/null
    source "${DOTFILES_ROOT}/lib/common.sh" 2>/dev/null || true
    log_info "Adding git aliases to .bashrc..."
    echo '' >> "${HOME}/.bashrc"
    echo '# Git aliases' >> "${HOME}/.bashrc"
    echo 'if [ -f ~/.git_aliases ]; then' >> "${HOME}/.bashrc"
    echo '    . ~/.git_aliases' >> "${HOME}/.bashrc"
    echo 'fi' >> "${HOME}/.bashrc"
fi
