#!/usr/bin/env bash
# shellcheck shell=bash

set -euo pipefail

# shellcheck source=../lib/common.sh
source "${DOTFILES_ROOT}/lib/common.sh"

log_info "Configuring aider..."

# Install aider if not present
AIDER_INSTALLED=false
if ! command_exists aider; then
    log_info "Installing aider..."
    
    # Priority 1: Homebrew
    if has_brew; then
        log_info "Installing aider via Homebrew..."
        if brew_install aider 2>/dev/null; then
            AIDER_INSTALLED=true
            log_info "Aider installed via Homebrew"
        else
            log_warn "Failed to install aider via Homebrew"
        fi
    fi
    
    # Priority 2: pipx (recommended for Python CLI tools)
    if [[ "$AIDER_INSTALLED" != true ]] && command -v pipx &>/dev/null; then
        log_info "Installing aider via pipx..."
        if pipx install aider-chat 2>/dev/null; then
            AIDER_INSTALLED=true
            log_info "Aider installed via pipx"
        else
            log_warn "Failed to install aider via pipx"
        fi
    fi
    
    # Priority 3: pip (user install)
    if [[ "$AIDER_INSTALLED" != true ]]; then
        log_info "Installing aider via pip..."
        if python3 -m pip install --user aider-chat 2>/dev/null; then
            AIDER_INSTALLED=true
            log_info "Aider installed via pip"
        else
            log_warn "Failed to install aider via pip, skipping..."
        fi
    fi
else
    AIDER_INSTALLED=true
fi

# Skip configuration if installation failed
if [[ "$AIDER_INSTALLED" != true ]]; then
    log_warn "Aider installation failed, skipping configuration"
    exit 0
fi

# Create config directory
ensure_dir "${HOME}/.config/aider"

# Link aider config
if [[ -f "${DOTFILES_ROOT}/aider/aider.conf.yml" ]]; then
    safe_link "${DOTFILES_ROOT}/aider/aider.conf.yml" "${HOME}/.config/aider/aider.conf.yml"
fi

# Add aliases to bash_aliases
if ! grep -q "alias ai=" "${HOME}/.bash_aliases" 2>/dev/null; then
    log_info "Adding aider aliases..."
    cat >> "${HOME}/.bash_aliases" << 'EOF'

# Aider aliases
alias ai='aider'
alias ais='aider --stream'
alias aic='aider --commit'
alias aia='aider --architect'
EOF
fi

log_info "Aider configuration complete!"
log_info "Usage: aider [files]"
