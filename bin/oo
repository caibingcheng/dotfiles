#!/bin/bash

# OpenCode tmux session launcher
# Creates split-screen layout: opencode (left) + terminal (right)

# Early help check
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: oo [model]"
    echo ""
    echo "Models:"
    echo "  (none)     Default model (oc)"
    echo "  c, copilot Copilot model (occ)"
    echo "  m, mix     Mixed model (ocm)"
    echo ""
    echo "Environment variables:"
    echo "  OO_SESSION_PREFIX  Session name prefix (default: opencode)"
    echo "  OO_SPLIT_RATIO     Right pane width percentage (default: 50)"
    exit 0
fi

set -e

# Configuration (override via environment variables)
SESSION_PREFIX="${OO_SESSION_PREFIX:-opencode}"
SPLIT_RATIO="${OO_SPLIT_RATIO:-50}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

error() { echo -e "${RED}Error:${NC} $1" >&2; exit 1; }
info() { echo -e "${GREEN}$1${NC}"; }
warn() { echo -e "${YELLOW}Warning:${NC} $1"; }

# Check dependencies
command -v tmux &> /dev/null || error "tmux not installed. Install with: sudo apt install tmux"

parse_args() {
    local model="default"

    while [[ $# -gt 0 ]]; do
        case $1 in
            c|copilot)
                model="copilot"
                shift
                ;;
            m|mix)
                model="mix"
                shift
                ;;
            *)
                warn "Unknown argument: $1"
                shift
                ;;
        esac
    done

    echo "$model"
}

get_opencode_cmd() {
    local model="$1"
    case "$model" in
        copilot) echo "occ" ;;
        mix)   echo "ocm" ;;
        *)      echo "oc" ;;
    esac
}

# Find next available session number
find_next_session_num() {
    local num=1
    while tmux has-session -t "${SESSION_PREFIX}${num}" 2>/dev/null; do
        ((num++))
    done
    echo "$num"
}

# Check if already in a tmux session
in_tmux() {
    [[ -n "$TMUX" ]]
}

main() {
    local model
    model=$(parse_args "$@")

    local opencode_cmd
    opencode_cmd=$(get_opencode_cmd "$model")

    # Find next available session number
    local session_num
    session_num=$(find_next_session_num)
    local session_name="${SESSION_PREFIX}${session_num}"

    # Create new tmux session
    local term_width
    term_width=$(tput cols 2>/dev/null || echo 160)
    local split_width=$((term_width / 2))

    if in_tmux; then
        # Already in tmux - create new session and switch
        tmux new-session -d -s "$session_name"
        tmux split-window -h -t "$session_name:1" -l "$split_width"
    else
        # Not in tmux - create session
        tmux new-session -d -s "$session_name"
        tmux split-window -h -t "$session_name:1" -l "$split_width"
    fi

    # Rename window
    tmux rename-window -t "$session_name:1" "OpenCode"

    # Start opencode in left pane
    tmux send-keys -t "$session_name:1.1" "$opencode_cmd" C-m

    # Focus left pane (opencode)
    tmux select-pane -t "$session_name:1.1"

    # Attach to session
    if in_tmux; then
        tmux switch-client -t "$session_name"
    else
        tmux attach-session -t "$session_name"
    fi
}

main "$@"