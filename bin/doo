#!/bin/bash

# OpenCode tmux session terminator
# Kills opencode sessions with smart detection

set -e

# Configuration (should match oo script)
SESSION_PREFIX="${OO_SESSION_PREFIX:-opencode}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

error() { echo -e "${RED}Error:${NC} $1" >&2; exit 1; }
info() { echo -e "${GREEN}$1${NC}"; }
warn() { echo -e "${YELLOW}Warning:${NC} $1"; }

# Check if in a tmux session
in_tmux() {
    [[ -n "$TMUX" ]]
}

# Get current session name
get_current_session() {
    tmux display-message -p '#{session_name}'
}

# List all opencode sessions
list_sessions() {
    local sessions
    sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${SESSION_PREFIX}" || true)
    
    if [[ -z "$sessions" ]]; then
        echo "No opencode sessions found."
        return 0
    fi
    
    echo "OpenCode sessions:"
    while IFS= read -r session; do
        local windows panes created
        windows=$(tmux list-windows -t "$session" -F '#{window_index}:#{window_name}' 2>/dev/null | tr '\n' ' ')
        panes=$(tmux list-panes -t "$session" -F '#{pane_index}' 2>/dev/null | wc -l)
        created=$(tmux list-sessions -F '#{session_created_string}' -f "#{==:#{session_name},$session}" 2>/dev/null | head -1)
        echo -e "  ${BLUE}${session}${NC} - windows: ${windows}panes: ${panes}created: ${created}"
    done <<< "$sessions"
}

# Kill a specific session
kill_session() {
    local session="$1"
    
    if ! tmux has-session -t "$session" 2>/dev/null; then
        warn "Session '$session' does not exist."
        return 1
    fi
    
    # If we're in this session, detach first
    if in_tmux && [[ "$(get_current_session)" == "$session" ]]; then
        tmux detach-client 2>/dev/null || true
    fi
    
    tmux kill-session -t "$session" 2>/dev/null
    info "Killed session: $session"
}

# Kill all opencode sessions
kill_all_sessions() {
    local sessions
    sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep "^${SESSION_PREFIX}" || true)
    
    if [[ -z "$sessions" ]]; then
        echo "No opencode sessions to kill."
        return 0
    fi
    
    local count=0
    for session in $sessions; do
        kill_session "$session" && ((count++))
    done
    
    info "Killed $count opencode session(s)."
}

# Kill current opencode session (if in one)
kill_current_session() {
    if ! in_tmux; then
        error "Not in a tmux session. Use 'doo <number>' to specify a session."
    fi
    
    local current
    current=$(get_current_session)
    
    if [[ ! "$current" =~ ^${SESSION_PREFIX}[0-9]+$ ]]; then
        error "Current session '$current' is not an opencode session."
    fi
    
    kill_session "$current"
}

# Kill session by number
kill_by_number() {
    local num="$1"
    local session="${SESSION_PREFIX}${num}"
    kill_session "$session"
}

show_help() {
    echo "Usage: doo [option|number]"
    echo ""
    echo "Options:"
    echo "  -l, --list      List all opencode sessions"
    echo "  -a, --all        Kill all opencode sessions"
    echo "  -h, --help       Show this help message"
    echo "  <number>         Kill specific session (e.g., 'doo 2' kills opencode2)"
    echo ""
    echo "If no argument provided:"
    echo "  - In opencode session: kill current session"
    echo "  - Outside tmux: list sessions"
    echo ""
    echo "Environment variables:"
    echo "  OO_SESSION_PREFIX  Session name prefix (default: opencode)"
}

main() {
    # No tmux available
    if ! command -v tmux &> /dev/null; then
        error "tmux not installed."
    fi
    
    # No arguments
    if [[ $# -eq 0 ]]; then
        if in_tmux; then
            kill_current_session
        else
            list_sessions
        fi
        exit 0
    fi
    
    # Parse arguments
    case "$1" in
        -l|--list)
            list_sessions
            ;;
        -a|--all)
            kill_all_sessions
            ;;
        -h|--help)
            show_help
            ;;
        [0-9]*)
            kill_by_number "$1"
            ;;
        *)
            error "Unknown option: $1. Use 'doo --help' for usage."
            ;;
    esac
}

main "$@"