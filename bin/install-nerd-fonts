#!/usr/bin/env bash
# Nerd Fonts Installation Script
# https://www.nerdfonts.com/

set -euo pipefail

readonly NERDFONTS_VERSION="3.2.1"
readonly FONTS_DIR="${HOME}/.local/share/fonts"

# 可选字体列表
readonly AVAILABLE_FONTS=(
    "JetBrainsMono"      # 推荐：JetBrains Mono
    "FiraCode"           # Fira Code
    "Hack"               # Hack
    "Meslo"              # Meslo (iTerm2 默认)
    "CascadiaCode"       # Cascadia Code (Windows Terminal)
    "SourceCodePro"      # Source Code Pro
    "UbuntuMono"         # Ubuntu Mono
    "DejaVuSansMono"     # DejaVu Sans Mono
    "Inconsolata"        # Inconsolata
)

# 颜色输出
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# 显示帮助信息
show_help() {
    cat <<EOF
Nerd Fonts Installation Script

Usage: $(basename "$0") [OPTIONS] [FONT_NAMES...]

OPTIONS:
    -h, --help          Show this help message
    -l, --list          List available fonts
    -a, --all           Install all fonts (not recommended)
    -u, --update        Update existing fonts
    -d, --dry-run       Show what would be installed without installing

FONT_NAMES:
    Space-separated list of font names to install
    Default: JetBrainsMono

Available Fonts:
EOF
    for font in "${AVAILABLE_FONTS[@]}"; do
        echo "  - $font"
    done
    echo ""
    echo "Examples:"
    echo "  $(basename "$0")                    # Install JetBrainsMono"
    echo "  $(basename "$0") JetBrainsMono FiraCode    # Install multiple fonts"
    echo "  $(basename "$0") --all              # Install all fonts"
    echo "  $(basename "$0") --list             # List available fonts"
}

# 列出可用字体
list_fonts() {
    echo "Available Nerd Fonts:"
    for font in "${AVAILABLE_FONTS[@]}"; do
        echo "  - $font"
    done
}

# 安装单个字体
install_font() {
    local font_name="$1"
    local dry_run="${2:-false}"
    
    local download_url="https://github.com/ryanoasis/nerd-fonts/releases/download/v${NERDFONTS_VERSION}/${font_name}.zip"
    local temp_dir=$(mktemp -d)
    local font_dir="${FONTS_DIR}/NerdFonts/${font_name}"
    
    log_info "Installing ${font_name}..."
    
    if [[ "$dry_run" == "true" ]]; then
        log_info "[DRY RUN] Would download: $download_url"
        log_info "[DRY RUN] Would install to: $font_dir"
        rm -rf "$temp_dir"
        return 0
    fi
    
    # 创建字体目录
    mkdir -p "$font_dir"
    
    # 下载字体
    log_info "Downloading ${font_name}..."
    if ! curl -fSL "$download_url" -o "${temp_dir}/${font_name}.zip" 2>/dev/null; then
        log_error "Failed to download ${font_name}"
        rm -rf "$temp_dir"
        return 1
    fi
    
    # 解压字体
    log_info "Extracting ${font_name}..."
    if ! unzip -q "${temp_dir}/${font_name}.zip" -d "$font_dir" 2>/dev/null; then
        log_error "Failed to extract ${font_name}"
        rm -rf "$temp_dir"
        return 1
    fi
    
    # 清理临时文件
    rm -rf "$temp_dir"
    
    log_info "${font_name} installed successfully to ${font_dir}"
    return 0
}

# 刷新字体缓存
refresh_font_cache() {
    log_info "Refreshing font cache..."
    
    if command -v fc-cache &>/dev/null; then
        fc-cache -fv "$FONTS_DIR" >/dev/null 2>&1
        log_info "Font cache refreshed"
    else
        log_warn "fc-cache not found, font cache not refreshed"
        log_warn "You may need to log out and log back in to see the fonts"
    fi
}

# 检查依赖
check_dependencies() {
    if ! command -v curl &>/dev/null; then
        log_error "curl is required but not installed"
        exit 1
    fi
    
    if ! command -v unzip &>/dev/null; then
        log_error "unzip is required but not installed"
        exit 1
    fi
}

# 主函数
main() {
    local fonts_to_install=()
    local install_all=false
    local dry_run=false
    local update_mode=false
    
    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -l|--list)
                list_fonts
                exit 0
                ;;
            -a|--all)
                install_all=true
                shift
                ;;
            -d|--dry-run)
                dry_run=true
                shift
                ;;
            -u|--update)
                update_mode=true
                shift
                ;;
            -*)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
            *)
                fonts_to_install+=("$1")
                shift
                ;;
        esac
    done
    
    # 检查依赖
    check_dependencies
    
    # 创建字体目录
    mkdir -p "$FONTS_DIR"
    
    # 确定要安装的字体
    if [[ "$install_all" == true ]]; then
        fonts_to_install=("${AVAILABLE_FONTS[@]}")
    elif [[ ${#fonts_to_install[@]} -eq 0 ]]; then
        # 默认安装 JetBrainsMono
        fonts_to_install=("JetBrainsMono")
    fi
    
    # 安装模式
    if [[ "$update_mode" == true ]]; then
        log_info "Update mode: removing old fonts..."
        rm -rf "${FONTS_DIR}/NerdFonts"
    fi
    
    # 安装字体
    local success_count=0
    local fail_count=0
    
    for font in "${fonts_to_install[@]}"; do
        if install_font "$font" "$dry_run"; then
            ((success_count++))
        else
            ((fail_count++))
        fi
    done
    
    # 刷新字体缓存（仅在非 dry-run 模式）
    if [[ "$dry_run" == "false" ]]; then
        refresh_font_cache
    fi
    
    # 总结
    echo ""
    log_info "Installation complete:"
    echo "  Success: $success_count"
    if [[ $fail_count -gt 0 ]]; then
        log_error "  Failed: $fail_count"
        exit 1
    fi
}

main "$@"
