#!/usr/bin/env bash
# shellcheck shell=bash
# Dotfiles Uninstallation Script

set -euo pipefail

# Colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }
log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

DOTFILES_ROOT="${HOME}/.dotfiles"
BACKUP_DIR="${HOME}/.dotfiles_backup_$(date +%Y%m%d_%H%M%S)"
DRY_RUN=false

show_help() {
    cat <<EOF
Dotfiles Uninstallation Script

Usage: $(basename "$0") [OPTIONS]

OPTIONS:
    -h, --help          Show this help message
    -d, --dry-run       Show what would be done without making changes
    -y, --yes           Skip confirmation prompts
    -k, --keep-backup   Keep backup after uninstall
    --full              Full uninstall including installed tools

DESCRIPTION:
    This script removes dotfiles configuration and restores backups.
    By default, it preserves installed tools (brew, rust, etc.)

EXAMPLES:
    $(basename "$0")              # Standard uninstall
    $(basename "$0") --dry-run    # Preview changes
    $(basename "$0") --full       # Uninstall including tools
EOF
}

confirm() {
    local msg="$1"
    if [[ "$DRY_RUN" == true ]]; then
        echo "[DRY RUN] Would prompt: $msg"
        return 0
    fi
    read -p "$msg [y/N] " -n 1 -r
    echo ""
    [[ $REPLY =~ ^[Yy]$ ]]
}

remove_link() {
    local target="$1"
    
    if [[ "$DRY_RUN" == true ]]; then
        echo "[DRY RUN] Would remove: $target"
        return 0
    fi
    
    if [[ -L "$target" ]]; then
        rm "$target"
        log_info "Removed symlink: $target"
    elif [[ -f "$target" ]]; then
        log_warn "Not removing regular file (not a symlink): $target"
    fi
}

restore_backup() {
    local file="$1"
    local backup_pattern="${file}.backup.*"
    
    # Find the most recent backup
    local backup_file
    backup_file=$(ls -t $backup_pattern 2>/dev/null | head -n1 || true)
    
    if [[ -n "$backup_file" && -f "$backup_file" ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo "[DRY RUN] Would restore: $backup_file -> $file"
        else
            mv "$backup_file" "$file"
            log_info "Restored backup: $(basename "$backup_file") -> $(basename "$file")"
        fi
    fi
}

uninstall_dotfiles() {
    log_info "Uninstalling dotfiles..."
    
    # Remove symlinks
    log_info "Removing symlinks..."
    
    # Bash
    remove_link "${HOME}/.bash_aliases"
    remove_link "${HOME}/.bash_profile"
    remove_link "${HOME}/.bashrc"
    remove_link "${HOME}/.profile"
    
    # Git
    remove_link "${HOME}/.gitconfig"
    remove_link "${HOME}/.gitignore_global"
    remove_link "${HOME}/.git-completion.bash"
    
    # Tmux
    remove_link "${HOME}/.tmux.conf.local"
    
    # SSH
    remove_link "${HOME}/.ssh/config"
    
    # Docker
    remove_link "${HOME}/.docker_aliases"
    
    # Starship
    remove_link "${HOME}/.config/starship.toml"
    
    # Direnv
    remove_link "${HOME}/.direnvrc"
    
    # Tealdeer
    remove_link "${HOME}/.config/tealdeer/config.toml"
    
    # Aider
    remove_link "${HOME}/.config/aider/aider.conf.yml"
    
    # Remove bin directory from PATH if managed by dotfiles
    # (We don't remove the bin directory itself, just unlink if it's a symlink)
    if [[ -L "${HOME}/bin" && "$(readlink "${HOME}/bin")" == "${DOTFILES_ROOT}/bin" ]]; then
        remove_link "${HOME}/bin"
    fi
    
    # Restore backups
    log_info "Restoring backups..."
    restore_backup "${HOME}/.bash_aliases"
    restore_backup "${HOME}/.bash_profile"
    restore_backup "${HOME}/.bashrc"
    restore_backup "${HOME}/.profile"
    restore_backup "${HOME}/.gitconfig"
    restore_backup "${HOME}/.gitignore_global"
    restore_backup "${HOME}/.tmux.conf.local"
    restore_backup "${HOME}/.ssh/config"
    
    # Remove initialization markers
    if [[ "$DRY_RUN" == true ]]; then
        echo "[DRY RUN] Would remove: ${HOME}/.dotfiles_initialized"
        echo "[DRY RUN] Would remove: ${HOME}/.dotfiles_install_level"
    else
        rm -f "${HOME}/.dotfiles_initialized"
        rm -f "${HOME}/.dotfiles_install_level"
        log_info "Removed initialization markers"
    fi
    
    # Backup and optionally remove dotfiles directory
    if [[ -d "$DOTFILES_ROOT" ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo "[DRY RUN] Would backup and remove: $DOTFILES_ROOT"
        else
            log_info "Backing up dotfiles directory to: $BACKUP_DIR"
            mv "$DOTFILES_ROOT" "$BACKUP_DIR"
            log_info "Dotfiles directory moved to backup"
        fi
    fi
}

uninstall_tools() {
    log_info "Uninstalling tools..."
    
    if [[ "$DRY_RUN" == true ]]; then
        echo "[DRY RUN] Would uninstall:"
        echo "  - Homebrew (optional)"
        echo "  - Rust (rustup self uninstall)"
        echo "  - Starship"
        echo "  - Direnv"
        return 0
    fi
    
    log_warn "Tool uninstallation is manual. Run these commands if needed:"
    echo ""
    echo "# Uninstall Homebrew (WARNING: removes all brew packages!)"
    echo "/bin/bash -c '\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/uninstall.sh)'"
    echo ""
    echo "# Uninstall Rust"
    echo "rustup self uninstall"
    echo ""
    echo "# Uninstall Starship"
    echo "rm -f ~/.local/bin/starship"
    echo ""
    echo "# Uninstall Direnv"
    echo "rm -f ~/.local/bin/direnv"
    echo ""
    echo "# Remove Homebrew from PATH (in ~/.bashrc)"
    echo "# Remove these lines:"
    echo "# eval '\$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)'"
}

# Parse arguments
FULL_UNINSTALL=false
SKIP_CONFIRM=false
KEEP_BACKUP=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        -d|--dry-run)
            DRY_RUN=true
            shift
            ;;
        -y|--yes)
            SKIP_CONFIRM=true
            shift
            ;;
        -k|--keep-backup)
            KEEP_BACKUP=true
            shift
            ;;
        --full)
            FULL_UNINSTALL=true
            shift
            ;;
        *)
            log_error "Unknown option: $1"
            show_help
            exit 1
            ;;
    esac
done

# Check if dotfiles are installed
if [[ ! -d "$DOTFILES_ROOT" ]]; then
    log_error "Dotfiles not found at $DOTFILES_ROOT"
    log_info "Nothing to uninstall"
    exit 1
fi

# Show summary
echo ""
echo "=== Dotfiles Uninstall Summary ==="
echo "Dotfiles location: $DOTFILES_ROOT"
echo "Dry run mode: $DRY_RUN"
echo "Full uninstall (including tools): $FULL_UNINSTALL"
echo ""

if [[ "$SKIP_CONFIRM" == false ]]; then
    if ! confirm "Continue with uninstallation?"; then
        log_info "Cancelled"
        exit 0
    fi
fi

# Run uninstallation
uninstall_dotfiles

if [[ "$FULL_UNINSTALL" == true ]]; then
    uninstall_tools
fi

if [[ "$DRY_RUN" == true ]]; then
    echo ""
    log_info "Dry run complete. No changes were made."
else
    echo ""
    log_info "Uninstallation complete!"
    
    if [[ -d "$BACKUP_DIR" && "$KEEP_BACKUP" == true ]]; then
        log_info "Backup kept at: $BACKUP_DIR"
    elif [[ -d "$BACKUP_DIR" ]]; then
        log_info "Backup location: $BACKUP_DIR"
        if confirm "Remove backup directory?"; then
            rm -rf "$BACKUP_DIR"
            log_info "Backup removed"
        fi
    fi
    
    echo ""
    log_info "Please restart your terminal to complete the uninstallation"
fi
