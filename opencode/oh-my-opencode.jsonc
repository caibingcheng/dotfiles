{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "bailian-coding-plan/kimi-k2.5",
      "prompt_append": "Response in Chinese, unless otherwise specified."

      // Fallback Chain: Claude Opus → Kimi K2.5 → GLM 5 (Claude-family only)
    },
    "oracle": {
      "prompt_append": "Response in Chinese, unless otherwise specified."

      // Fallback Chain: GPT-5.2 → Gemini 3 Pro → Claude Opus (Read-only high-IQ consultation)
    },
