{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "bailian-coding-plan/glm-5",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: claude-opus-4-6 (default) → kimi-k2.5 → glm-4.7 → gemini-3-pro (Main orchestrator)
    },
    "oracle": {
      "model": "github-copilot/gpt-5.2",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: gpt-5.2 (default) → claude-opus-4-6 → gemini-3-pro (Read-only consultation)
    },
    "librarian": {
      "model": "github-copilot/gpt-5-mini",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: glm-4.7 (default) → big-pickle → claude-sonnet-4-6 (External docs/code search)
    },
    "explore": {
      "model": "github-copilot/gpt-5-mini",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: grok-code-fast-1 (default) → claude-haiku-4-5 → gpt-5-nano (Contextual grep)
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-flash-preview",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: gemini-3-flash (default) → gpt-5.2 → glm-4.6v → ... (6 deep, PDF/image analysis)
    },
    "prometheus": {
      "model": "bailian-coding-plan/kimi-k2.5",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: claude-opus-4-6 (default) → kimi-k2.5 → gpt-5.2 → gemini-3-pro (Strategic planner)
    },
    "metis": {
      "model": "bailian-coding-plan/kimi-k2.5",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: claude-opus-4-6 (default) → kimi-k2.5 → gpt-5.2 → gemini-3-pro (Pre-planning consultant)
    },
    "momus": {
      "model": "github-copilot/gpt-5.2",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: gpt-5.2 (default) → claude-opus-4-6 → gemini-3-pro (Plan reviewer)
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: claude-sonnet-4-6 (default) → kimi-k2.5 → gpt-5.2 → gemini-3-pro (Todo-list orchestrator)
    },
    "ask": {
      "model": "github-copilot/gpt-4.1",
      "prompt_append": "Response in Chinese, unless otherwise specified."
    },
    "translate": {
      "model": "github-copilot/gpt-4.1",
      "prompt_append": "Response in Chinese, unless otherwise specified."
    }
  },
  "categories": {
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: claude-sonnet-4-6 (default) → user-configurable (Category-spawned executor)
    },
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: Gemini 3 Pro → GLM 5 → Claude Opus (Frontend/UI/Design)
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.2-codex",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: GPT-5.3 Codex → Gemini 3 Pro → Claude Opus (Maximum reasoning)
    },
    "deep": {
      "model": "github-copilot/gpt-5.2-codex",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: GPT-5.3 Codex → Claude Opus → Gemini 3 Pro (Deep coding/complex logic)
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: Gemini 3 Pro → Claude Opus → GPT-5.2 (Creative/novel approaches)
    },
    "quick": {
      "model": "github-copilot/claude-haiku-4.5",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: Claude Haiku → Gemini Flash → GPT-5-Nano (Simple/fast tasks)
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: Claude Sonnet → GPT-5.3 Codex → Gemini Flash (General standard work)
    },
    "unspecified-high": {
      "model": "github-copilot/gpt-5.2",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: Claude Opus → GPT-5.2 → Gemini 3 Pro (General complex work)
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview",
      "prompt_append": "Response in Chinese, unless otherwise specified."
      // Fallback Chain: Gemini Flash → Claude Sonnet (Text/docs/prose)
    }
  }
}
